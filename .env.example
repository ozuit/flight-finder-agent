# GreenNode IAM credentials (required)
# Get from: https://iam.console.vngcloud.vn/service-accounts
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=

# LLM provider (any OpenAI-compatible API)
# GreenNode AIP:   LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# OpenAI:          LLM_BASE_URL=https://api.openai.com/v1
# Ollama (local):  LLM_BASE_URL=http://localhost:11434/v1  (no key needed)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# AgentBase Memory (optional — leave empty to disable memory)
# Create a memory store with: /agentbase-memory
MEMORY_ID=
MEMORY_STRATEGY_ID=default

# Flight data provider: serpapi (Google Flights) | mock
FLIGHT_API_PROVIDER=serpapi

# SerpAPI Google Flights (required when FLIGHT_API_PROVIDER=serpapi)
# Get your API key at: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=
SERPAPI_GL=vn
SERPAPI_HL=vi
# true gives results closer to the Google Flights UI but is slower
SERPAPI_DEEP_SEARCH=false
